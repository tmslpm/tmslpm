{
	"name": "tmslpm public (prod)",
	"image": "mcr.microsoft.com/devcontainers/base:noble",
	"features": {
		"ghcr.io/devcontainers/features/python:1": {
			"installTools": false
		},
		"ghcr.io/devcontainers/features/common-utils": {
			"installZsh": true,
			"configureZshAsDefaultShell": true
		}
	},
	"postCreateCommand": "sudo apt-get update && sudo apt-get install -y m4 minify cmark",
	"customizations": {
		"codespaces": {
			"openFiles": [
				"README.md"
			]
		},
		"vscode": {
			"extensions": [
				"ms-vscode.live-server"
			]
		}
	}
}
